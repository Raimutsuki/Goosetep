<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/task_background"
    android:layout_marginBottom="12dp">

    <!-- Заголовок цели -->
    <LinearLayout
        android:id="@+id/goalHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackground">

        <TextView
            android:id="@+id/goalTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FF6200EE"
            android:textSize="18sp"
            android:textStyle="bold" />

        <!-- Кнопка удаления -->
        <ImageView
            android:id="@+id/btnDeleteGoal"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@android:drawable/ic_delete"
            app:tint="#CCCCCC"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone"
            android:layout_marginEnd="8dp"
            android:contentDescription="Удалить цель" />

        <ImageView
            android:id="@+id/expandIcon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/keyboard_arrow_down" />

    </LinearLayout>

    <!-- Прогресс-бар -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/progressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0/0"
            android:textColor="#CCCCCC"
            android:textSize="12sp"
            android:layout_marginEnd="8dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="20dp"
            android:layout_weight="1"
            android:progressTint="#FF6200EE"
            android:progressBackgroundTint="#444444" />

    </LinearLayout>

    <!-- Контейнер для задач и подзадач -->
    <LinearLayout
        android:id="@+id/subtasksContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:animateLayoutChanges="true"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp" />

</LinearLayout>